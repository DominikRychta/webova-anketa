<!DOCTYPE html>
<html lang="cs">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= poll.title %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>
  <main class="page-shell">
    <section class="hero card">
      <div class="hero-copy">
        <p class="eyebrow">Hudba a volný čas</p>
        <h1><%= poll.title %></h1>
        <p class="lead"><%= poll.description %></p>
      </div>
      <div class="hero-stats">
        <div class="stat-box">
          <span class="stat-number"><%= totalResponses %></span>
          <span class="stat-label">odeslaných odpovědí</span>
        </div>
        <a class="button button-secondary" href="/results">Zobrazit výsledky</a>
      </div>
    </section>

    <% if (error) { %>
      <div class="alert alert-error"><%= error %></div>
    <% } %>

    <form class="card form-card" action="/submit" method="POST">
      <input type="hidden" name="surveyId" value="<%= poll.id %>" />

      <div class="form-grid">
        <label class="field">
          <span>Jméno</span>
          <input type="text" name="respondentName" placeholder="Vaše jméno" required minlength="2" />
        </label>

        <% poll.questions.forEach((question, index) => { %>
          <div class="question-block">
            <div class="question-head">
              <h2><%= index + 1 %>. <%= question.text %></h2>
              <p><%= question.helpText %></p>
            </div>

            <% if (Array.isArray(question.options) && question.options.length > 0) { %>
              <div class="options <%= question.type === 'scale' ? 'scale-options' : '' %>">
                <% question.options.forEach((option, optionIndex) => { %>
                  <label class="option <%= question.type === 'scale' ? 'scale-option' : '' %>">
                    <input type="radio" name="q_<%= question.id %>" value="<%= option %>" required />
                    <span><%= option %></span>
                  </label>
                <% }) %>
              </div>
            <% } else { %>
              <label class="field">
                <span>Vaše odpověď</span>
                <textarea name="q_<%= question.id %>" rows="4" placeholder="Napište odpověď..." required minlength="2"></textarea>
              </label>
            <% } %>
          </div>
        <% }) %>
      </div>

      <button class="button button-primary" type="submit">Odeslat odpověď</button>
    </form>
  </main>
</body>
</html>
